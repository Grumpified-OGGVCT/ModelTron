<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ModelTron Engine: Enterprise Model Ranking System</title>
    <style>
        :root {
            --bg-dark: #0f172a;
            --bg-panel: #1e293b;
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
            --accent: #38bdf8;
            --success: #22c55e;
            --warning: #f59e0b;
            --danger: #ef4444;
            --border: #334155;
            --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        }

        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            line-height: 1.5;
        }

        /* Focus styles for keyboard accessibility */
        :focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 2px;
        }

        /* Skip to main content link */
        .skip-link {
            position: absolute;
            top: -40px;
            left: 0;
            background: var(--accent);
            color: var(--bg-dark);
            padding: 8px;
            z-index: 100;
            transition: top 0.2s ease-in-out;
            text-decoration: none;
            font-weight: bold;
        }

        .skip-link:focus {
            top: 0;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        header {
            text-align: center;
            margin-bottom: 3rem;
        }

        h1 {
            color: var(--accent);
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
        }

        .subtitle {
            color: var(--text-dim);
            font-size: 1.1rem;
        }

        .panel {
            background-color: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 0.5rem;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
        }

        th, td {
            padding: 1rem;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        th {
            color: var(--text-dim);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.875rem;
        }

        tr:last-child td {
            border-bottom: none;
        }

        .rank {
            font-weight: bold;
            color: var(--accent);
        }

        .model-name {
            font-family: var(--font-mono);
            background: rgba(56, 189, 248, 0.1);
            padding: 0.2rem 0.4rem;
            border-radius: 0.25rem;
            color: var(--accent);
        }

        .score {
            font-weight: bold;
            color: var(--success);
        }

        .category {
            color: var(--warning);
        }

        /* Stats Grid semantic update to list */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
            list-style: none; /* Remove default list bullets */
            padding-left: 0; /* Remove default list padding */
        }

        .stat-card {
            background-color: var(--bg-panel);
            border: 1px solid var(--border);
            border-radius: 0.5rem;
            padding: 1.5rem;
            text-align: center;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: bold;
            color: var(--accent);
        }

        .stat-label {
            color: var(--text-dim);
            font-size: 0.875rem;
            text-transform: uppercase;
            margin-top: 0.5rem;
        }

        #api-demo {
            font-family: var(--font-mono);
            background: #000;
            padding: 1rem;
            border-radius: 0.5rem;
            color: var(--success);
            overflow-x: auto;
        }
    </style>
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <div class="container">
        <header>
            <h1>⚖ ModelTron Engine</h1>
            <div class="subtitle">Enterprise Model Ranking System (v2026.1)</div>
        </header>

        <main id="main-content">
            <ul class="stats-grid" aria-label="System Statistics">
                <li class="stat-card">
                    <div class="stat-value">8</div>
                    <div class="stat-label">Capability Categories</div>
                </li>
                <li class="stat-card">
                    <div class="stat-value">12+</div>
                    <div class="stat-label">Models Verified</div>
                </li>
                <li class="stat-card">
                    <div class="stat-value">Deterministic</div>
                    <div class="stat-label">Grading Pipeline</div>
                </li>
                <li class="stat-card">
                    <div class="stat-value">11434</div>
                    <div class="stat-label">Local Agent Port</div>
                </li>
            </ul>

            <section class="panel" aria-labelledby="leaderboard-heading">
                <h2 id="leaderboard-heading">🏆 Verified Leaderboard</h2>
                <p class="subtitle">Rankings based on deterministic execution and human-reviewed rubrics.</p>
                <div role="region" aria-label="Leaderboard table" tabindex="0" class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th scope="col">Rank</th>
                                <th scope="col">Model</th>
                                <th scope="col">Primary Role</th>
                                <th scope="col">Score</th>
                            </tr>
                        </thead>
                        <tbody id="leaderboard-body" aria-live="polite" aria-atomic="true">
                            <tr>
                                <td class="rank">#1</td>
                                <td><span class="model-name">deepseek-v3.2:cloud</span></td>
                                <td class="category">Reasoning & Logic</td>
                                <td class="score">98.2</td>
                            </tr>
                            <tr>
                                <td class="rank">#2</td>
                                <td><span class="model-name">glm-5:cloud</span></td>
                                <td class="category">Structured Outputs</td>
                                <td class="score">97.5</td>
                            </tr>
                            <tr>
                                <td class="rank">#3</td>
                                <td><span class="model-name">minimax-m2.5:cloud</span></td>
                                <td class="category">Code Generation</td>
                                <td class="score">96.8</td>
                            </tr>
                            <tr>
                                <td class="rank">#4</td>
                                <td><span class="model-name">qwen3-vl:235b-cloud</span></td>
                                <td class="category">Multimodal</td>
                                <td class="score">90.0</td>
                            </tr>
                            <tr>
                                <td class="rank">#5</td>
                                <td><span class="model-name">qwen3.5:397b-cloud</span></td>
                                <td class="category">Agentic Workflows</td>
                                <td class="score">88.5</td>
                            </tr>
                            <tr>
                                <td class="rank">#6</td>
                                <td><span class="model-name">gemini-3-flash-preview:cloud</span></td>
                                <td class="category">Context Management</td>
                                <td class="score">87.2</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="panel" aria-labelledby="api-integration-heading">
                <h2 id="api-integration-heading">🔌 API Integration</h2>
                <p>Access the ModelTron engine programmatically via the <code>/v1/recommend</code> endpoint.</p>
                <div id="api-demo" role="region" aria-label="API Request Example" tabindex="0">
$ curl -X GET "http://localhost:8000/v1/recommend?task_type=code_generation"
{
  "recommendation_id": "rec_7b82f91a",
  "timestamp": "2026-03-04T21:30:00Z",
  "recommended_model": "minimax-m2.5:cloud",
  "reasoning": "Ranked #1 for code_generation.",
  "confidence_score": 0.95
}
                </div>
            </section>
        </main>
    </div>

    <script>
        // In a real deployment, this would fetch from the /v1/rankings endpoint
        console.log("ModelTron UI initialized.");

        async function fetchRankings() {
            try {
                // If the local API is running, we could fetch data here.
                // const response = await fetch('http://localhost:8000/v1/rankings');
                // const data = await response.json();
                // updateTable(data.leaderboard);

                // Example of screen reader announcement for dynamic state updates
                // document.getElementById('leaderboard-body').setAttribute('aria-label', 'Leaderboard updated successfully');
            } catch(e) {
                console.log("Using static data while API is offline.");
                // Error announcement
                const tbody = document.getElementById('leaderboard-body');
                if(tbody) {
                  const errorMsg = document.createElement('tr');
                  errorMsg.innerHTML = '<td colspan="4" style="color: var(--danger); text-align: center;">Using static data while API is offline.</td>';
                  // Only visually hide if we just want SR announcement, but for errors visual is good too.
                  // tbody.appendChild(errorMsg); // Decided not to append visual error as it breaks static demo layout, but logging is fine for this example.
                }
            }
        }

        fetchRankings();
    </script>
</body>
</html>
